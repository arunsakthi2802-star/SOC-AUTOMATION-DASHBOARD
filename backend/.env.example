# Backend — Environment Variables Template
# Copy this file to .env in the backend/ folder and fill in real values.
# NEVER commit the actual .env file.

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=<appName>
DATABASE_NAME=soc_automation

# ─── JWT ──────────────────────────────────────────────────────────────────────
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-strong-random-secret-key-here

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# In production, set this to your Vercel URL, e.g.:
# CORS_ORIGINS=https://soc-dashboard.vercel.app
# For local dev, leave as wildcard:
CORS_ORIGINS=*
