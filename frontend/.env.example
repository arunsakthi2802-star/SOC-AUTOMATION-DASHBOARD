# Frontend — Environment Variables Template
# For Vercel: set VITE_API_BASE_URL in Project Settings → Environment Variables.
# For local dev: copy to .env.local (automatically gitignored by Vite).

# URL of your deployed FastAPI backend (no trailing slash, include /api)
# Vercel production example:
# VITE_API_BASE_URL=https://your-backend.railway.app/api
# Local dev default (used if var is unset):
VITE_API_BASE_URL=http://localhost:8000/api
